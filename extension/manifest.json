{
  "manifest_version": 3,
  "name": "Thumbnail Board",
  "version": "2.0",
  "description": "Save YouTube thumbnails to your Thumbnail Board with tags",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:3000/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
